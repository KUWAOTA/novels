    <diagram id="diary-private-novel-0310" name="Page-1">
        <mxGraphModel dx="986" dy="324" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="日記私小説ラフ設計 2026-03-09 to 2026-03-10" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=22;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="540" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="用途: note用の短い私小説。まずは構造の羅針盤だけ作る。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12" parent="1" vertex="1">
                    <mxGeometry x="40" y="55" width="420" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#28A745;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="440" height="290" as="geometry"/>
                </mxCell>
                <mxCell id="11" value="Controlling Concept / Value" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="60" y="115" width="280" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="12" value="統制概念:&lt;br&gt;比較に呑まれて感情を切断するほど、創作は死ぬ。みじめさを観測し他者の目を借りて言葉に変えたとき、停滞はかろうじて表現へ反転する。" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="60" y="155" width="400" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="対立概念:&lt;br&gt;感情に乱される未熟な人間には、創作の資格がない。勝てないなら降りるしかない。" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="60" y="230" width="390" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="14" value="主要価値軸:&lt;br&gt;1. 創作との接続  dead -&gt; faint alive&lt;br&gt;2. 自己認識  denial -&gt; observation&lt;br&gt;3. 他者との接続  isolation -&gt; mediated contact" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="60" y="295" width="370" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="20" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#4A7FB5;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="510" y="100" width="480" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="21" value="Protagonist / Pressure" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="530" y="115" width="230" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="22" value="主人公: 批評も構造化もできるが、敗北感に極端に弱い語り手" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="530" y="155" width="410" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="23" value="意志: それでも創作を続けたい&lt;br&gt;顕在欲望: 自分がまだ書けることを証明したい&lt;br&gt;無意識の欲望: 未熟でも価値があると感じたい&lt;br&gt;対象: 次の一文、次の小説の入口" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="530" y="190" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="24" value="善の中心:&lt;br&gt;創作に対する執着は本物&lt;br&gt;恥を隠さず素材化しようとする" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="770" y="190" width="180" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="25" value="4層メモ:&lt;br&gt;社会的自己: 論理的で強い人&lt;br&gt;個人的自己: 恋人に弱さを見せる&lt;br&gt;中核: 負けたくない、創作したい&lt;br&gt;隠れた自己: エリートでない自分を愛せない" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="770" y="255" width="200" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="26" value="圧力シーケンス:&lt;br&gt;後輩の指摘 -&gt; 比較意識暴走 -&gt; 創作嫌悪 -&gt; 孤立 -&gt; 外部の声で再接続" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="530" y="285" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="30" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#7B4F9E;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="1020" y="100" width="520" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="31" value="Character Dimension / Cast" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="1040" y="115" width="260" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="32" value="主人公の矛盾:&lt;br&gt;A. 言語化が得意 / 感情を処理できない&lt;br&gt;B. 勝負を嫌う / 隣の誰かには負けたくない&lt;br&gt;C. 創作したい / 創作物そのものがセピアに見える" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="1040" y="155" width="250" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="33" value="キャスト機能:&lt;br&gt;後輩: 契機事件を起こす外圧 / 鑑識眼の代理&lt;br&gt;萌子: 受容の言葉を与えるが、まだ凍りを割りきれない&lt;br&gt;ネットの友人: 同じ創作の苦しみを知る声として氷を溶かす&lt;br&gt;語り手自身: 自己批判者であり、敵対者でもある" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="1310" y="155" width="210" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="34" value="ポラリティ:&lt;br&gt;後輩 = 正しさ / 萌子 = 受容 / 友人 = 同業の体温 / 主人公 = 勝敗と羞恥" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="1040" y="270" width="480" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="40" value="Short Story Arc" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="395" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="41" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#E67E22;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="60" y="450" width="250" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="42" value="Setup / Inciting Incident" style="text;html=1;strokeColor=none;fillColor=#000000;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="90" y="465" width="190" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="43" value="3/9 夜。後輩との創作相談。&lt;br&gt;有益な指摘を受けたはずなのに、語り手はそれを『自分の敗北』として受け取る。&lt;br&gt;&lt;br&gt;価値変化:&lt;br&gt;創作への接続 + から - へ&lt;br&gt;自己像 stable から cracked へ" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="80" y="505" width="210" height="135" as="geometry"/>
                </mxCell>
                <mxCell id="44" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#C0392B;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="380" y="450" width="250" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="45" value="Progressive Complication" style="text;html=1;strokeColor=none;fillColor=#000000;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="415" y="465" width="180" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="46" value="萌子とのLINEで、負けず嫌い、完璧主義、感情観測不能が露出。&lt;br&gt;翌日には小説もアニメも漫画も『セピア』に見え、ベッドから動けない。&lt;br&gt;&lt;br&gt;価値変化:&lt;br&gt;自己認識 shallow -&gt; raw&lt;br&gt;他者接続 thin -&gt; needed" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="400" y="505" width="210" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="47" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#28A745;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="700" y="450" width="260" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="48" value="Crisis / Climax / Tiny Resolution" style="text;html=1;strokeColor=none;fillColor=#000000;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="730" y="465" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="49" value="人と話さないと人の形を保てない。スペースに繋ぎ、友人の『悔しいだけやろ』『楽しい時しか楽しいものは作れない』に触れる。&lt;br&gt;&lt;br&gt;結末は治癒ではなく、凍った創作欲が少しだけ溶けるところで止める。&lt;br&gt;&lt;br&gt;価値変化:&lt;br&gt;孤立 -&gt; 微弱な接続&lt;br&gt;創作死 -&gt; 書けるかもしれない" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="720" y="505" width="220" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="50" value="" style="endArrow=classic;html=1;strokeWidth=2;fillColor=#000000;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="310" y="555" as="sourcePoint"/>
                        <mxPoint x="380" y="555" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="51" value="" style="endArrow=classic;html=1;strokeWidth=2;fillColor=#000000;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="630" y="555" as="sourcePoint"/>
                        <mxPoint x="700" y="555" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="60" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#E67E22;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="430" width="510" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="61" value="Image / Symbol / Discernment" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="1050" y="445" width="260" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="62" value="反復イメージ候補:&lt;br&gt;ベッドでうずくまる身体 / セピア色になった創作物 / 机を叩く手 / インターネット越しの他人の目 / 凍った氷が少し溶ける感覚" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="1050" y="485" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="63" value="中核イメージ案:&lt;br&gt;暗い部屋で縮こまっていた身体が、見えない誰かの声に押されて、端末へ手を伸ばす。" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="1290" y="485" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="64" value="鑑識眼チェック:&lt;br&gt;・後輩を悪役化しない&lt;br&gt;・萌子を『癒やし装置』にしない&lt;br&gt;・主人公の被害者意識を美化しない&lt;br&gt;・説明しすぎず、身体感覚と行動で見せる" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="1050" y="600" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="65" value="note向け文体メモ:&lt;br&gt;短い現在進行の文を中心に。&lt;br&gt;結論で救わず、観測で止める。&lt;br&gt;『病み』は演出ではなく、思考の癖として見せる。" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13" parent="1" vertex="1">
                    <mxGeometry x="1290" y="590" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="70" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#4A7FB5;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="40" y="735" width="920" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="71" value="次に文章化するときの最小プロット" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="60" y="750" width="260" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="72" value="1. 有益な指摘を受けた夜、なぜか『学び』ではなく『敗北』として体に入ってしまう。&lt;br&gt;2. 恋人との対話で、自分が感情を観測せずに論理へ逃がしていたことが少しだけ見える。&lt;br&gt;3. 翌日、創作物すべてが色褪せ、ベッドの中で人の形を失いかける。&lt;br&gt;4. それでも外部の声に繋ぎ、同業の友人の言葉で『悔しいだけだ』と輪郭を与えられる。&lt;br&gt;5. 救われきらないまま、書けるかもしれない場所にだけ戻って終わる。" style="text;html=1;strokeColor=none;fillColor=#000000;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14" parent="1" vertex="1">
                    <mxGeometry x="60" y="790" width="870" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="73" value="" style="edgeStyle=none;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#000000;fillColor=#000000;" edge="1" parent="1">
                    <mxGeometry width="80" relative="1" as="geometry">
                        <mxPoint x="530" y="210" as="sourcePoint"/>
                        <mxPoint x="610" y="210" as="targetPoint"/>
                        <Array as="points"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="74" value="Text" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="280" y="660" width="60" height="30" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
