<mxfile host="65bd71144e">
    <diagram id="fish-mckee" name="金魚 McKee構造分析">
        <mxGraphModel dx="766" dy="932" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                
                <mxCell id="title" value="&lt;b&gt;友人作『金魚』 — McKee構造分析マップ&lt;/b&gt;&lt;br&gt;2026-03-08 story-compiler準拠" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontColor=#1B3A5C;fillColor=none;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="300" y="-180" width="600" height="60" as="geometry"/>
                </mxCell>
                
                <mxCell id="cc_box" value="&lt;b&gt;統制概念 (Controlling Concept)&lt;/b&gt;&lt;br&gt;&lt;br&gt;人は欠落や狂気を抱えながらも、&lt;br&gt;ささやかな勇気（タバコ等）と他者の受容によって、&lt;br&gt;現実の繋がり（社会）へ回帰することができる。&lt;br&gt;&lt;br&gt;&lt;b&gt;対立概念:&lt;/b&gt;&lt;br&gt;自身の病理や他者の狂気に引きずり込まれ、一生孤立する。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="400" y="-100" width="400" height="130" as="geometry"/>
                </mxCell>
                
                <mxCell id="theme" value="&lt;b&gt;象徴（金魚と雪解け）&lt;/b&gt;&lt;br&gt;雪解け ＝ 精神的な凍結（孤立）からの解放&lt;br&gt;エアタバコ（金魚の口パク） ＝ 虚構の行為&lt;br&gt;実際の喫煙 ＝ 現実世界への干渉" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#4A7FB5;fontColor=#1B3A5C;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="50" y="-100" width="300" height="80" as="geometry"/>
                </mxCell>
                
                <mxCell id="value_arc" value="&lt;b&gt;価値変化弧&lt;/b&gt;&lt;br&gt;孤立・無意識の病的行動（エアタバコ）&lt;br&gt;→ 虚栄心と他者への擬似接続（Discord）&lt;br&gt;→ 現実の受容（共に勉強する）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="850" y="-100" width="300" height="80" as="geometry"/>
                </mxCell>
                
                <mxCell id="tri_title" value="&lt;b&gt;三角構造&lt;/b&gt;" style="text;html=1;align=center;fontSize=14;fontColor=#1B3A5C;" parent="1" vertex="1">
                    <mxGeometry x="1250" y="-260" width="200" height="30" as="geometry"/>
                </mxCell>
                
                <mxCell id="tri_discord" value="&lt;b&gt;Discordの女性（影）&lt;/b&gt;&lt;br&gt;自殺未遂・精神病棟&lt;br&gt;主人公の病理の引力（落ちる沼）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAF0;strokeColor=#7B4F9E;fontColor=#3D1F5C;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1250" y="-210" width="200" height="60" as="geometry"/>
                </mxCell>
                
                <mxCell id="tri_takuya" value="&lt;b&gt;拓也（媒介者）&lt;/b&gt;&lt;br&gt;狂気（自殺する彼女）を扱いながら&lt;br&gt;日常のカロリー（ラーメン）にする特異点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#E67E22;fontColor=#6E3B0A;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1250" y="-40" width="200" height="60" as="geometry"/>
                </mxCell>
                
                <mxCell id="tri_protag" value="&lt;b&gt;主人公（ヒロセ）&lt;/b&gt;&lt;br&gt;境界線を歩く金魚&lt;br&gt;「現実への適応」を求める" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#4A7FB5;fontColor=#1B3A5C;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="-130" width="100" height="70" as="geometry"/>
                </mxCell>
                
                <mxCell id="tri_normal" value="&lt;b&gt;悠木・聡太（健全な日常）&lt;/b&gt;&lt;br&gt;タバコ、授業、テスト勉強" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1450" y="-125" width="200" height="60" as="geometry"/>
                </mxCell>
                
                <mxCell id="tri_edge1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7B4F9E;" parent="1" source="tri_discord" target="tri_protag" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                
                <mxCell id="tri_edge2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E67E22;" parent="1" source="tri_takuya" target="tri_protag" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                
                <mxCell id="tri_edge3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#28A745;dashed=1;" parent="1" source="tri_protag" target="tri_normal" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                
                <mxCell id="seq1" value="&lt;b&gt;1. 雪解けと喫煙所&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 雪解けの音（変化の始まり）&lt;br&gt;• 喫煙所デビュー&lt;br&gt;• エアタバコからの脱却&lt;br&gt;• 「金魚」の指摘&lt;br&gt;&lt;br&gt;【状態】虚構から物理的行動へ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#4A7FB5;fontColor=#1B3A5C;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="50" y="80" width="250" height="150" as="geometry"/>
                </mxCell>
                
                <mxCell id="seq2" value="&lt;b&gt;2. 薬と食事の境界&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 混在する匂いへの吐き気&lt;br&gt;• Inゼリーと6錠の薬&lt;br&gt;• 休学と孤立感の吐露&lt;br&gt;• 友達を作るための喫煙の合理化&lt;br&gt;&lt;br&gt;【状態】自身の病と目的の確認" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0E0;strokeColor=#C0392B;fontColor=#5C1B1B;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="340" y="80" width="250" height="150" as="geometry"/>
                </mxCell>
                
                <mxCell id="seq3" value="&lt;b&gt;3. 日常生活と狂気の侵食&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 課題への苦痛（眼球のストライキ）&lt;br&gt;• 障害を持つDiscordの女性との通話&lt;br&gt;• 虚栄心を満たすだけの非生産的関係&lt;br&gt;• 悠木への「友達紹介して」の依頼&lt;br&gt;• 拓也の彼女の自殺騒動とラーメン&lt;br&gt;&lt;br&gt;【状態】狂気の可視化と日常への執着" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAF0;strokeColor=#7B4F9E;fontColor=#3D1F5C;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="630" y="80" width="250" height="180" as="geometry"/>
                </mxCell>
                
                <mxCell id="seq4" value="&lt;b&gt;4. 決断と受容（結末）&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 女性からの「自殺未遂・付き合いたい」&lt;br&gt;• 病理的な執着への引き込み&lt;br&gt;• 困惑し、自身のレベルを自己批判&lt;br&gt;• &lt;font color=&quot;#28A745&quot;&gt;能動的な決断:&lt;/font&gt; 「一緒に勉強していいかな？」&lt;br&gt;• 悠木の「もちろん」という無条件の受容&lt;br&gt;&lt;br&gt;【価値変化】孤立 → 現実の他者への接続" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="920" y="80" width="270" height="180" as="geometry"/>
                </mxCell>
                
                <mxCell id="seq5_predict" value="&lt;b&gt;5. 今後の予測（短編の続きがあるなら）&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;契機事件:&lt;/b&gt; 精神病棟の彼女が現実のキャンパスに侵食してくる。&lt;br&gt;• &lt;b&gt;葛藤の増大:&lt;/b&gt; 悠木や聡太との「擬似的な健全さ」が試される。主人公は、自分が彼女と同じ「そちら側」なのか、それとも「こちら側」なのかの選択を迫られる。&lt;br&gt;• スモーカーとしてのアイデンティティ崩壊の危機。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontColor=#333333;fontSize=10;align=left;spacingLeft=8;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="80" width="280" height="180" as="geometry"/>
                </mxCell>
                
                <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#4A7FB5;" parent="1" source="seq1" target="seq2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#4A7FB5;" parent="1" source="seq2" target="seq3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e34" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#4A7FB5;" parent="1" source="seq3" target="seq4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e45" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#999999;dashed=1;" parent="1" source="seq4" target="seq5_predict" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
