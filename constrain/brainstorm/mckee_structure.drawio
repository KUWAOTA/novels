        <!-- ============================== -->
        <!-- McKee COMPILER CHECKLIST -->
        <!-- ============================== -->
        <mxCell id="ck_title" value="&lt;b&gt;McKeeコンパイラ チェックリスト&lt;/b&gt;" style="text;html=1;align=left;fontSize=14;fontColor=#C0392B;" vertex="1" parent="1">
          <mxGeometry x="50" y="420" width="400" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="ck1" value="&lt;b&gt;✅ 契機事件 (Inciting Incident)&lt;/b&gt;&lt;br&gt;父の死 → 均衡破壊 → 誤信念の種&lt;br&gt;配置：ACT1末尾（25%制約を満たす）&lt;br&gt;伏線：持病・車いす・月1面会&lt;br&gt;回収：❓（クライマックスで記憶として回収？）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="460" width="350" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="ck2" value="&lt;b&gt;✅ 誤信念 (Misbelief)&lt;/b&gt;&lt;br&gt;「正確に理解すれば人は救える」&lt;br&gt;根拠：B子の幸福死を苦痛死と誤解&lt;br&gt;強化：灘・東大での成功体験&lt;br&gt;崩壊：ACT4の善意の暴力→鏡像認識" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="420" y="460" width="350" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="ck3" value="&lt;b&gt;✅ 否定の否定 (Negation of Negation)&lt;/b&gt;&lt;br&gt;• 教育・導き → 放置 → &lt;b&gt;善意の教育で人を壊す&lt;/b&gt;&lt;br&gt;• 理解 → 無知 → &lt;b&gt;「理解」という名の支配&lt;/b&gt;&lt;br&gt;• 愛される → 愛されない → &lt;b&gt;愛された者が愛されなかった者を追い詰める&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="580" width="500" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="ck4" value="&lt;b&gt;❌ 統制概念 (Controlling Concept)&lt;/b&gt;&lt;br&gt;未確定。候補はあるがクライマックスと&lt;br&gt;連動して確定する必要がある。&lt;br&gt;&lt;br&gt;&lt;b&gt;対立概念も未確定。&lt;/b&gt;&lt;br&gt;教条主義チェック: 実行不能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0E0;strokeColor=#C0392B;strokeWidth=2;fontColor=#5C1B1B;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="580" y="580" width="350" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="ck5" value="&lt;b&gt;❌ クライマックス (Climax)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;確定事項:&lt;/b&gt;&lt;br&gt;• A男が自殺を企図する&lt;br&gt;• B子のトラウマが生きてくる&lt;br&gt;&lt;br&gt;&lt;b&gt;未設計:&lt;/b&gt;&lt;br&gt;• 主人公はどう行動するか？&lt;br&gt;• 不可逆な価値変化は何か？&lt;br&gt;• 統制概念の体現方法は？&lt;br&gt;• 「理解→愛」の弧はどこで着地？&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#999999&quot;&gt;&lt;b&gt;旧案（廃案）:&lt;/b&gt;&lt;br&gt;~~銃で撃たれながら抱きしめる~~&lt;br&gt;~~叫ぶ（マスクを外す）~~&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0E0;strokeColor=#C0392B;strokeWidth=3;fontColor=#5C1B1B;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="460" width="320" height="250" as="geometry"/>
        </mxCell>

        <mxCell id="ck6" value="&lt;b&gt;❌ エンディング&lt;/b&gt;&lt;br&gt;未設計。旧案：数年後の面会室&lt;br&gt;A男が自殺企図に変更された場合&lt;br&gt;面会室の設定が成立するか？" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0E0;strokeColor=#C0392B;strokeWidth=2;fontColor=#5C1B1B;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1300" y="580" width="250" height="80" as="geometry"/>
        </mxCell>

        <!-- ============================== -->
        <!-- CAUSAL CHAIN: A男 -->
        <!-- ============================== -->
        <mxCell id="causal_title" value="&lt;b&gt;因果連鎖 — A男&lt;/b&gt;" style="text;html=1;align=left;fontSize=14;fontColor=#E67E22;" vertex="1" parent="1">
          <mxGeometry x="50" y="700" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="c1" value="A男の家庭虐待&lt;br&gt;（成績＝愛情）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#E67E22;fontColor=#6E3B0A;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="740" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="c2" value="才能型主人公への嫉妬&lt;br&gt;＋父の愛への嫉妬" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#E67E22;fontColor=#6E3B0A;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="200" y="740" width="140" height="40" as="geometry"/>
