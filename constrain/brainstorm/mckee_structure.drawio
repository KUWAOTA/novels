<mxfile host="app.diagrams.net" modified="2026-03-08T14:29:00.000Z" agent="Antigravity" version="24.0.0" type="device">
  <diagram id="constrain-mckee" name="Constrain McKee構造分析">
    <mxGraphModel dx="3200" dy="2400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ============================== -->
        <!-- TITLE -->
        <!-- ============================== -->
        <mxCell id="title" value="&lt;b&gt;Constrain — McKee構造分析マップ&lt;/b&gt;&lt;br&gt;2026-03-08 current_plot.md準拠" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontColor=#1B3A5C;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="-180" width="600" height="60" as="geometry"/>
        </mxCell>

        <!-- ============================== -->
        <!-- CONTROLLING CONCEPT -->
        <!-- ============================== -->
        <mxCell id="cc_box" value="&lt;b&gt;統制概念 (Controlling Concept)&lt;/b&gt;&lt;br&gt;&lt;br&gt;❓ 未確定&lt;br&gt;候補: 人は曖昧で不完全だし傷つけ合うし&lt;br&gt;取り戻せない過ちを何度も繰り返すけど&lt;br&gt;それでも人を愛しましょう&lt;br&gt;&lt;br&gt;&lt;b&gt;対立概念:&lt;/b&gt;&lt;br&gt;厳密さだけが人を救い正しい世界を作る" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0E0;strokeColor=#C0392B;fontColor=#5C1B1B;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="-100" width="400" height="130" as="geometry"/>
        </mxCell>

        <!-- ============================== -->
        <!-- THEME & VALUE ARC -->
        <!-- ============================== -->
        <mxCell id="theme" value="&lt;b&gt;テーマ一文&lt;/b&gt;&lt;br&gt;厳密さで世界を守ろうとした人間が&lt;br&gt;誤解と傷でできた社会を&lt;br&gt;それでも愛せるようになる話" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#4A7FB5;fontColor=#1B3A5C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="-100" width="300" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="value_arc" value="&lt;b&gt;価値変化弧（確定）&lt;/b&gt;&lt;br&gt;理解すれば救える&lt;br&gt;→ 理解しても救えない&lt;br&gt;→ 理解できなくても寄り添える" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="-100" width="300" height="80" as="geometry"/>
        </mxCell>

        <!-- ============================== -->
        <!-- TRIANGLE -->
        <!-- ============================== -->
        <mxCell id="tri_title" value="&lt;b&gt;三角構造&lt;/b&gt;" style="text;html=1;align=center;fontSize=14;fontColor=#1B3A5C;" vertex="1" parent="1">
          <mxGeometry x="1250" y="-100" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="tri_b" value="&lt;b&gt;B子（鏡像）&lt;/b&gt;&lt;br&gt;厳密さが足りない社会で死んだ&lt;br&gt;→ 厳密さ = 救いの証拠" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAF0;strokeColor=#7B4F9E;fontColor=#3D1F5C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1250" y="-60" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="tri_protag" value="&lt;b&gt;主人公&lt;/b&gt;&lt;br&gt;両方を理解し&lt;br&gt;「それでも愛する」を選択" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#4A7FB5;fontColor=#1B3A5C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1300" y="20" width="100" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="tri_a" value="&lt;b&gt;A男（逆像）&lt;/b&gt;&lt;br&gt;厳密さの世界で壊れた&lt;br&gt;→ 厳密さ = 暴力の証拠" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#E67E22;fontColor=#6E3B0A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1250" y="100" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="tri_edge1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7B4F9E;" edge="1" parent="1" source="tri_b" target="tri_protag"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="tri_edge2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E67E22;" edge="1" parent="1" source="tri_a" target="tri_protag"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============================== -->
        <!-- ACT STRUCTURE -->
        <!-- ============================== -->

        <!-- ACT 1 -->
        <mxCell id="act1" value="&lt;b&gt;ACT 1 — 小学生&lt;/b&gt;&lt;br&gt;&lt;br&gt;• ASDで浮いている（疎外）&lt;br&gt;• 父が論理・仮説・数式を教える&lt;br&gt;• A男が主人公に嫉妬（成績＋父の愛）&lt;br&gt;• 中学入直後、父の死&lt;br&gt;&lt;br&gt;&lt;b&gt;価値変化:&lt;/b&gt; 安全→孤立&lt;br&gt;&lt;b&gt;契機事件:&lt;/b&gt; 父の死" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#4A7FB5;fontColor=#1B3A5C;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="60" width="250" height="180" as="geometry"/>
        </mxCell>

        <!-- ACT 2 -->
        <mxCell id="act2" value="&lt;b&gt;ACT 2 — 中学時代&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 保健室登校→B子と出会う&lt;br&gt;• A男：教育虐待が加速&lt;br&gt;• A男のいじめが過激化（双方苦しい）&lt;br&gt;• B子が心のよりどころに&lt;br&gt;• 論理・仮説でいじめをかわす&lt;br&gt;• &lt;font color=&quot;#C0392B&quot;&gt;B子：幸せの絶頂で自殺&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;価値変化:&lt;/b&gt; 孤立→繋がり→喪失&lt;br&gt;&lt;b&gt;誤信念確立:&lt;/b&gt; 厳密なら救えた" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAF0;strokeColor=#7B4F9E;fontColor=#3D1F5C;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="60" width="250" height="200" as="geometry"/>
        </mxCell>

        <!-- ACT 3 -->
        <mxCell id="act3" value="&lt;b&gt;ACT 3 — 灘高校～東大&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 灘合格。A男：灘落ち→二番手高校&lt;br&gt;• エリートコミュニティで適応&lt;br&gt;• 厳密な言葉=馴染める場所と発見&lt;br&gt;• 東大合格。A男：東大落ち→東工大&lt;br&gt;• B子を救えた後悔→厳密さへの確信&lt;br&gt;&lt;br&gt;&lt;b&gt;価値変化:&lt;/b&gt; 喪失→使命感&lt;br&gt;&lt;b&gt;A男サブ:&lt;/b&gt; 連敗の蓄積" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#2C6FAC;fontColor=#1B3A5C;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="630" y="60" width="250" height="180" as="geometry"/>
        </mxCell>

        <!-- ACT 4 -->
        <mxCell id="act4" value="&lt;b&gt;ACT 4 — 社会人時代&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Google Japan就職（実力 vs コミュ力）&lt;br&gt;• A男：ストーキングして同じ会社に&lt;br&gt;• 主人公が先に昇進→A男が部下に&lt;br&gt;• &lt;font color=&quot;#C0392B&quot;&gt;善意の「教育」→無自覚な加害&lt;/font&gt;&lt;br&gt;• A男にとって教育=いじめの構図&lt;br&gt;• A男が崩壊・出社不能に&lt;br&gt;• &lt;font color=&quot;#C0392B&quot;&gt;鏡像認識：自分がA男と同じことをしている&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;価値変化:&lt;/b&gt; 正義→加害（無自覚→自覚）&lt;br&gt;&lt;b&gt;否定の否定:&lt;/b&gt; 善意の教育で人を壊す" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#E67E22;fontColor=#6E3B0A;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="920" y="60" width="280" height="220" as="geometry"/>
        </mxCell>

        <!-- ACT 5 (CLIMAX) -->
        <mxCell id="act5" value="&lt;b&gt;ACT 5 — クライマックス&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#C0392B&quot;&gt;⚠ 未設計 — 最重要課題&lt;/font&gt;&lt;br&gt;&lt;br&gt;• A男が自殺を企図する&lt;br&gt;  （B子の自殺トラウマが呼応）&lt;br&gt;• 主人公はどう行動するか？&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#C0392B&quot;&gt;&lt;b&gt;必要条件（McKee）:&lt;/b&gt;&lt;/font&gt;&lt;br&gt;□ 中央価値軸が決着&lt;br&gt;□ 不可逆な価値変化&lt;br&gt;□ 因果連鎖が完結&lt;br&gt;□ 統制概念の体現&lt;br&gt;□ 期待と結果の最大ギャップ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0E0;strokeColor=#C0392B;strokeWidth=3;fontColor=#5C1B1B;fontSize=10;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1240" y="60" width="280" height="230" as="geometry"/>
        </mxCell>

        <!-- Arrows between ACTs -->
        <mxCell id="a12" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#4A7FB5;" edge="1" parent="1" source="act1" target="act2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a23" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#4A7FB5;" edge="1" parent="1" source="act2" target="act3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a34" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#4A7FB5;" edge="1" parent="1" source="act3" target="act4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a45" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#C0392B;" edge="1" parent="1" source="act4" target="act5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============================== -->
        <!-- VALUE FLOW -->
        <!-- ============================== -->
        <mxCell id="vf_title" value="&lt;b&gt;価値変化フロー&lt;/b&gt;" style="text;html=1;align=center;fontSize=14;fontColor=#1B3A5C;" vertex="1" parent="1">
          <mxGeometry x="50" y="310" width="200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="v1" value="安全" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="350" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="v2" value="孤立" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#4A7FB5;fontColor=#1B3A5C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="350" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="v3" value="繋がり&lt;br&gt;（B子）" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E8DAF0;strokeColor=#7B4F9E;fontColor=#3D1F5C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="350" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="v4" value="喪失&lt;br&gt;（B子死）" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F5C6CB;strokeColor=#C0392B;fontColor=#5C1B1B;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="350" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="v5" value="使命感&lt;br&gt;（誤信念）" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#2C6FAC;fontColor=#1B3A5C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="350" width="90" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="v6" value="成功&lt;br&gt;（厳密の勝利）" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#28A745;fontColor=#1B4332;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="350" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="v7" value="加害&lt;br&gt;（善意の暴力）" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#E67E22;fontColor=#6E3B0A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="350" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="v8" value="自覚&lt;br&gt;（鏡像認識）" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F5C6CB;strokeColor=#C0392B;fontColor=#5C1B1B;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1040" y="350" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="v9" value="&lt;b&gt;❓&lt;br&gt;クライマックス&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE0E0;strokeColor=#C0392B;strokeWidth=2;fontColor=#5C1B1B;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1200" y="345" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="v10" value="共存&lt;br&gt;（愛）" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FADBD8;strokeColor=#E74C6F;fontColor=#5C1B1B;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1380" y="350" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- Value flow arrows -->
        <mxCell id="vf12" style="strokeWidth=1;strokeColor=#888888;" edge="1" parent="1" source="v1" target="v2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="vf23" style="strokeWidth=1;strokeColor=#888888;" edge="1" parent="1" source="v2" target="v3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="vf34" style="strokeWidth=1;strokeColor=#888888;" edge="1" parent="1" source="v3" target="v4"><mxGeometry relative="1" as="geometry"/></mxCell>
