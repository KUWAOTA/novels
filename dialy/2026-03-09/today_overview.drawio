    <mxCell id="notdo" value="今日やらないこと&#xa;・立派な答えの完成&#xa;・学校向けの模範解答づくり&#xa;・気分だけ整えて満足" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;" vertex="1" parent="1">
