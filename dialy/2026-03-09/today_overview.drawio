    <mxCell id="p1" value="最優先1&#xa;何を書きたいのか" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=18;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="120" y="300" width="500" height="80" as="geometry" />
    </mxCell>
    <mxCell id="p1body" value="目的&#xa;・学校の話が自分に必要か判断する軸を先に作る&#xa;&#xa;書く内容&#xa;・ひとことで: constrain&#xa;・今書きたい題材&#xa;・なぜそれを書きたいか&#xa;&#xa;まだ足りない点&#xa;・作品像と問題意識を切り分ける&#xa;・必要な学びが構成訓練か文章/批評かを書く&#xa;&#xa;創作への返り&#xa;・今後も何を核に書くかを定める" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF3FF;strokeColor=#6C8EBF;fontSize=13;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="120" y="390" width="500" height="290" as="geometry" />
    </mxCell>

    <mxCell id="p2" value="最優先2&#xa;今の課題は何か" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=18;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="710" y="300" width="500" height="80" as="geometry" />
    </mxCell>
    <mxCell id="p2body" value="目的&#xa;・学校が良さそうかではなく、自分の課題に効くかで見る&#xa;&#xa;書く項目&#xa;・技術面の課題&#xa;・習慣面の課題&#xa;・環境面の課題&#xa;・今すぐ変えられること&#xa;&#xa;判断の観点&#xa;・能力不足か作業設計不足か&#xa;・学校でないと解決しづらい課題は何か&#xa;・一人でも改善できる課題は何か&#xa;&#xa;創作への返り&#xa;・進学判断と同時に自習方針も立つ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7EA;strokeColor=#82B366;fontSize=13;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="710" y="390" width="500" height="290" as="geometry" />
    </mxCell>

    <mxCell id="p3" value="最優先3&#xa;当日に確認したいことを1つ作る" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=18;fontStyle=1;" vertex="1" parent="1">
