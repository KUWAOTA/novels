    <mxCell id="sub1" value="A. 書きたい核&#xa;何を書きたいのか&#xa;なぜそれを書きたいのか" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF3FF;strokeColor=#6C8EBF;fontSize=15;fontStyle=1;" vertex="1" parent="1">
